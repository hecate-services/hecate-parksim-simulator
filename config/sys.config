[
 {hecate_parksim, [
   {http_port, 8473},
   %% Default scenario. Override via env (PARKSIM_SHAPE, PARKSIM_TIME_SCALE, …)
   %% or the /api/run cowboy endpoint.
   {shape,       "city"},   %% "demo" | "city" | "stress"
   {time_scale,  1.0},      %% 1.0 = real-time
   {seed,        0},        %% 0 = pick from os timestamp
   {include_evacuation, false},
   %% Set to true to skip macula:call and log the would-be RPC instead.
   %% Useful when no station is reachable. Crashes are reported as
   %% mesh_unavailable; production runs leave this false.
   {dry_run,     true}
 ]},
 {kernel, [
   {logger_level, info}
 ]}
].
