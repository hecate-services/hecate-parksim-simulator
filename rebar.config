%% -*- mode: erlang -*-
%% rebar3 configuration for hecate-parksim — the majestic monolith.
%%
%% A self-contained parking simulator. One container instance per
%% tenant. Each instance owns a reckon-db store (parksim_<tenant>_store)
%% and self-announces to reckon_db_store_registry via pg, so reckon-gateway's
%% catalogue mode sees every tenant cluster-wide.

{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
    %% Tagged (not {branch}): branch deps froze in the CI rebar3/Docker cache,
    %% serving the pre-fix hecate_om. A tag busts every cache + fetches
    %% reliably. v0.3.1 = the mesh-connect fix (deferred+retry, cert-decoupled).
    {hecate_om, {git, "https://codeberg.org/hecate-services/hecate-om.git", {tag, "v0.3.1"}}},

    %% Top-level git override of reckon_db's transitive khepri 0.17.2.
    %% Carries the does_path_match-on-delete crash fix (see the fork's
    %% FORK.md); fork vsn stays 0.17.2 so reckon_db's exact pin is met.
    %% Drop once the fix lands in an upstream khepri release.
    {khepri, {git, "https://codeberg.org/reckon-db-org/khepri.git", {tag, "v0.17.2-reckon1"}}},

    {reckon_db,    "~> 3.1"},
    {evoq,         "~> 1.15"},
    {reckon_evoq,  "~> 2.1"},
    {reckon_gater, "~> 2.3"},

    {cowboy,  "~> 2.12.0"},
    {esqlite, "~> 0.8.0"}
]}.

{relx, [
    {release, {hecate_parksim, "0.1.0"}, [
        hecate_parksim,

        hecate_om,
        reckon_db,
        evoq,
        reckon_evoq,

        parksim_simulator,
        guide_parking_session_lifecycle,
        project_parking_sessions,
        query_parking_sessions,
        simulate_clock,
        simulate_arrivals,
        simulate_visit
    ]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true}
]}.

{shell, [
    {config, "config/sys.config"},
    {apps, [hecate_parksim]}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true},
            {sys_config_src, "config/sys.config.src"},
            {vm_args_src,    "config/vm.args.src"}
        ]}
    ]}
]}.
