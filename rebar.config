%% -*- mode: erlang -*-
%% rebar3 configuration for hecate-parksim-simulator.

{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
    {hecate_om, {git, "https://codeberg.org/hecate-services/hecate-om.git", {branch, "main"}}},
    {macula,    {git, "https://codeberg.org/macula-io/macula.git",          {branch, "main"}}},
    {cowboy,  "~> 2.12.0"}
]}.

{relx, [
    {release, {hecate_parksim_simulator, "0.1.0"}, [
        hecate_parksim_simulator,

        hecate_om,
        macula,

        parksim_simulator,
        simulate_clock,
        simulate_arrivals,
        simulate_visit,
        simulate_lots,
        simulate_pricing
    ]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true}
]}.

{shell, [
    {config, "config/sys.config"},
    {apps, [hecate_parksim_simulator]}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true},
            {sys_config_src, "config/sys.config.src"},
            {vm_args_src,    "config/vm.args.src"}
        ]}
    ]}
]}.
